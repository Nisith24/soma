# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web API Key for your Firebase project
FIREBASE_API_KEY=PLACEHOLDER_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: Project ID of your Firebase project
FIREBASE_PROJECT_ID=PLACEHOLDER_FIREBASE_PROJECT_ID

# FIREBASE_APP_ID: Application ID (App ID) of your Android app in Firebase console
FIREBASE_APP_ID=PLACEHOLDER_FIREBASE_APP_ID

# GOOGLE_WEB_CLIENT_ID: Web Client ID for Google Sign-In from Firebase / Google Cloud Console
GOOGLE_WEB_CLIENT_ID=PLACEHOLDER_GOOGLE_WEB_CLIENT_ID
